{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "bookings": {
      "$bid": {
        ".validate": "!newData.exists() || (newData.hasChild('updatedAt') && newData.child('updatedAt').isNumber() && (!data.exists() || newData.child('updatedAt').val() > data.child('updatedAt').val()))"
      }
    }
  }
}
