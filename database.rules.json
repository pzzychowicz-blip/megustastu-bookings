{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "bookings": {
      ".validate": "newData.parent().child('bookingsRev').val() === (data.parent().child('bookingsRev').exists() ? data.parent().child('bookingsRev').val() + 1 : 1)"
    },
    "bookingsRev": {
      ".validate": "newData.isNumber() && (data.exists() ? newData.val() === data.val() + 1 : newData.val() === 1)"
    }
  }
}
