# .env.local.example — WhatsApp backend configuration template.
# Copy to .env.local (gitignored via *.local) and fill in. The local harness
# (npm run wa:backend) reads .env.local; on Vercel these become project env
# vars at ship time.

# ── Database ──────────────────────────────────────────────────────────────────
# RTDB url. LEAVE UNSET for the sandbox — it defaults to the DEV database.
# Ship time only: set the PROD url explicitly on Vercel.
# WA_DB_URL=

# Service-account key for the DEV Firebase project, pasted AS ONE LINE.
# Firebase console → (DEV project) Project settings → Service accounts →
# Generate new private key → open the .json → flatten to one line → paste:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"megustastu-bookings-dev",...}

# ── LLM (Gemini, Google AI Studio free tier) ──────────────────────────────────
# GEMINI_API_KEY=            # AI Studio key (new "AQ.…" format) — real value in .env.local only
# WA_LLM_MODE=live            # mock (default, no network) | live
# GEMINI_MODEL=gemini-3-flash # confirm via: curl localhost:3999/dev/models

# ── Outbound sending ──────────────────────────────────────────────────────────
# WA_SEND_MODE=mock           # mock (default) | live (needs the two below)
# META_WA_TOKEN=              # Cloud API bearer token (ship time)
# META_PHONE_NUMBER_ID=       # the restaurant number's Cloud API id (ship time)

# ── Webhook security ──────────────────────────────────────────────────────────
# META_VERIFY_TOKEN=          # any string you choose; pasted into Meta's
#                             # webhook config at ship time (harness default:
#                             # local-dev-verify)
# META_APP_SECRET=            # Meta app secret for HMAC verification (ship time)
# WA_ALLOW_UNSIGNED=1         # harness sets this; NEVER set it on Vercel
